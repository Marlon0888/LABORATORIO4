#include <iostream>
using namespace std;

int main() {
    double a, b;

    cin >> a >> b;

    cout << a + b << endl;
    cout << a - b << endl;
    cout << a * b << endl;

    if(b != 0)
        cout << a / b << endl;
    else
        cout << "No se puede dividir\n";

    if(a > b)
        cout << "A es mayor\n";
    else if(b > a)
        cout << "B es mayor\n";
    else
        cout << "Son iguales\n";

    return 0;
}
