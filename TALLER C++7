#include <iostream>
#include <string>
#include <ctime>
using namespace std;

int main() {
    string nombre;
    getline(cin, nombre);

    cout << nombre.length() << endl;

    for(int i = 0; i < nombre.length(); i++)
        nombre[i] = toupper(nombre[i]);

    cout << nombre << endl;

    time_t t = time(0);
    tm *now = localtime(&t);

    cout << (now->tm_year + 1900) << endl;

    string user = nombre.substr(0,3) + to_string(now->tm_year + 1900);
    cout << user << endl;

    return 0;
}
